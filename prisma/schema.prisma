generator client {
  provider = "prisma-client"
  output   = "../src/server/.db"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workosId      String   @unique
  isVerified    Boolean  @default(false)
  authChangedAt DateTime @default(now())

  name      String
  avatarUrl String?

  vaults Vault[]
}

model Vault {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name     String
  testAuth String

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  vaultRecords VaultRecord[]
}

model VaultRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  type RecordType
  data Json /* Array<{ key: value }> */

  vaultId String
  vault   Vault  @relation(fields: [vaultId], references: [id])
}

enum RecordType {
  PASSWORD
  API_KEY
  NOTE
}
